<IfModule mod_rewrite.c>
  RewriteEngine On

  # Redirect non-www to www (Fixes 403 on non-www)
  RewriteCond %{HTTP_HOST} ^techvantage\.blog [NC]
  RewriteRule ^(.*)$ https://www.techvantage.blog/$1 [L,R=301]

  # Redirect if ending in .html to remove the .html extension
  RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /([^.]+)\.html\ HTTP
  RewriteRule ^(.*)\.html$ /$1 [R=301,L]

  # If the requested URI doesn't end in .html, and there is no such directory...
  RewriteCond %{REQUEST_URI} !\.html$
  RewriteCond %{REQUEST_FILENAME} !-d
  # ...and an .html file with that name exists, rewrite to the .html file.
  RewriteCond %{REQUEST_FILENAME}\.html -f
  RewriteRule ^(.*)$ $1.html [L]
</IfModule>

# Disable directory listing to avoid 403 Forbidden errors when looking for index
Options -Indexes

# ============================================================
# PERFORMANCE: Browser Cache Headers (fixes Lighthouse warning)
# ============================================================
<IfModule mod_expires.c>
  ExpiresActive On

  # Images — 1 year
  ExpiresByType image/webp                    "access plus 1 year"
  ExpiresByType image/jpeg                    "access plus 1 year"
  ExpiresByType image/png                     "access plus 1 year"
  ExpiresByType image/gif                     "access plus 1 year"
  ExpiresByType image/svg+xml                 "access plus 1 year"
  ExpiresByType image/x-icon                  "access plus 1 year"

  # Fonts — 1 year
  ExpiresByType font/woff2                    "access plus 1 year"
  ExpiresByType font/woff                     "access plus 1 year"
  ExpiresByType application/font-woff2        "access plus 1 year"

  # Scripts & Styles — 1 year (Next.js uses content hashes)
  ExpiresByType text/javascript               "access plus 1 year"
  ExpiresByType application/javascript        "access plus 1 year"
  ExpiresByType text/css                      "access plus 1 year"

  # HTML — 1 hour (revalidate frequently for news site)
  ExpiresByType text/html                     "access plus 1 hour"

  # Default fallback — 1 week
  ExpiresDefault                              "access plus 1 week"
</IfModule>

# ============================================================
# PERFORMANCE: Cache-Control headers for CDN/proxy compatibility
# ============================================================
<IfModule mod_headers.c>
  # Long-lived immutable assets (images, JS, CSS with content hashes)
  <FilesMatch "\.(webp|jpg|jpeg|png|gif|ico|svg|woff2|woff|js|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # HTML — revalidate
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>

  # Vary: Accept-Encoding for all text responses
  <FilesMatch "\.(html|css|js|xml|json|txt)$">
    Header append Vary Accept-Encoding
  </FilesMatch>
</IfModule>

# ============================================================
# PERFORMANCE: Gzip/Deflate Compression
# ============================================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
  AddOutputFilterByType DEFLATE application/javascript text/javascript
  AddOutputFilterByType DEFLATE application/json application/xml
  AddOutputFilterByType DEFLATE font/woff font/woff2 image/svg+xml
</IfModule>

